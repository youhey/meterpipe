APP_NAME="meterpipe"
APP_ENV="local"
APP_KEY=
APP_DEBUG=true
APP_URL="http://localhost:8080"

APP_LOCALE="en"
APP_FALLBACK_LOCALE="en"
APP_FAKER_LOCALE="en_US"

APP_MAINTENANCE_DRIVER="file"
# APP_MAINTENANCE_STORE="database"

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL="stderr"
LOG_STACK="stderr"
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL="debug"

DB_CONNECTION="mysql"
DB_HOST="mysql"
DB_PORT=3306
DB_DATABASE="meterpipe"
DB_USERNAME="meterpipe"
DB_PASSWORD="meterpipe"

SESSION_DRIVER="redis"
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH="/"
SESSION_DOMAIN=null

BROADCAST_CONNECTION="log"
FILESYSTEM_DISK="s3"
QUEUE_CONNECTION="database"

CACHE_STORE="redis"
# CACHE_PREFIX=

MEMCACHED_HOST="127.0.0.1"

REDIS_CLIENT="phpredis"
REDIS_HOST="valkey"
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER="log"
MAIL_SCHEME=null
MAIL_HOST="127.0.0.1"
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_DEFAULT_REGION="us-east-1"
AWS_BUCKET="meterpipe-local"
AWS_ENDPOINT="http://minio:9000"
AWS_URL="http://localhost:9000/meterpipe-local"
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

OPENAI_ADMIN_KEY=
OPENAI_COST_SYNC_DAYS=30

LARAVEL_CLOUD_API_TOKEN=
LARAVEL_CLOUD_COST_SYNC_DAYS=30

METERPIPE_OPENAI_COLLECTOR_ENABLED=false

METERPIPE_LARAVEL_CLOUD_COLLECTOR_ENABLED=false

METERPIPE_DEFAULT_CURRENCY="usd"

METERPIPE_COST_SYNC_QUEUE="default"
METERPIPE_COST_SYNC_POLLING_INTERVAL="30s"

METERPIPE_MONTHLY_BUDGET_AMOUNT=0
METERPIPE_MONTHLY_BUDGET_CURRENCY="usd"

METERPIPE_ADMIN_ALLOWED_EMAILS=

METERPIPE_ADMIN_DEV_LOGIN_ENABLED=false
METERPIPE_ADMIN_DEV_LOGIN_EMAIL=
